# === NODO — Máquina de leads ===
# Copia este archivo a ".env.local" y rellena lo que tengas.
# TODO es opcional: sin credenciales, la app corre en "modo demo" y el flujo
# igual se ejecuta de principio a fin (clasificador por reglas, almacenamiento
# en memoria, correo/telegram simulados). Cada credencial que agregues
# "enciende" esa etapa con datos reales.

# --- IA (clasificación de leads) ---
# Sin esta clave se usa un clasificador por reglas (heurístico) como fallback.
ANTHROPIC_API_KEY=
# Modelo del clasificador. Default barato para demo público. Súbelo a
# claude-opus-4-8 si quieres máxima calidad.
CLASSIFIER_MODEL=claude-haiku-4-5

# --- Base de datos (Neon / Postgres serverless) ---
# Sin esto, los leads se guardan en memoria (se pierden al reiniciar).
DATABASE_URL=

# --- Correo de bienvenida (Resend) ---
# Sin esto, el correo se "simula" y se registra en los logs.
RESEND_API_KEY=
# Remitente verificado en Resend. Usa onboarding@resend.dev para pruebas.
MAIL_FROM=NODO <onboarding@resend.dev>

# --- Notificación a Telegram ---
# Sin esto, la notificación se "simula" y se registra en los logs.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
